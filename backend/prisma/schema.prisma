generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Cliente {
  id          Int          @id @default(autoincrement())
  cpf         String       @unique
  nome        String
  rua         String
  numero      Int
  bairro      String
  assinaturas Assinatura[] // Relacionamento com Assinatura
}

model Assinatura {
  id             Int      @id @default(autoincrement())
  clienteCpf     String
  dataAssinatura DateTime
  quantidade     Int

  cliente Cliente @relation(fields: [clienteCpf], references: [cpf], onDelete: Cascade)

  @@unique([clienteCpf, dataAssinatura]) // Evita duplicidade na mesma data
}
